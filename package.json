{
  "name": "library-management-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,cron -c auto \"next dev\" \"yarn cron\"",
    "dev:socket": "ts-node --project tsconfig.server.json server/socket-server.ts",
    "build": "next build",
    "start": "yarn build && concurrently -k -n web,cron -c auto \"next start\" \"yarn cron\"",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "test:assessment": "jest --config jest.assessment.config.ts --runInBand --silent --noStackTrace",
    "test:sheet:recommendations": "jest --config jest.sheets.config.ts --runInBand --verbose --silent tests/services/gorse.service.test.ts tests/assessment/recommendations.assessment.test.ts --noStackTrace",
    "test:sheet:vector-search": "jest --config jest.sheets.config.ts --runInBand --verbose --silent tests/services/qdrant.service.test.ts tests/assessment/vector-search.assessment.test.ts --noStackTrace",
    "test:sheet:ai-summaries": "jest --config jest.sheets.config.ts --runInBand --verbose --silent tests/services/ollama.service.test.ts tests/services/gemini.service.test.ts tests/assessment/ai-summaries.assessment.test.ts --noStackTrace",
    "test:sheet:dashboard-analytics": "jest --config jest.sheets.config.ts --runInBand --verbose --silent tests/api/dashboard.routes.test.ts tests/api/dashboard.extended-routes.test.ts --noStackTrace",
    "test:sheet:notifications-performance": "jest --config jest.sheets.config.ts --runInBand --verbose --silent tests/services/notification.service.test.ts tests/workers/notification.worker.test.ts tests/assessment/notifications.assessment.test.ts --noStackTrace",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "seed": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" prisma/seed.ts",
    "seed:books": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" prisma/seed-books-from-json.ts",
    "seed:users": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" prisma/seed-users.ts",
    "fetch:google-books": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" prisma/fetch-google-books.ts",
    "sync:gorse": "node node_modules/ts-node/dist/bin.js --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/sync-gorse-data.ts",
    "mock:gorse-feedback": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/mock-gorse-feedback-smart.ts",
    "worker": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/workers.ts",
    "cron": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/cron.ts",
    "sync:qdrant": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" scripts/sync-book-qdrant.ts",
    "test:sheet:recommendations:clean": "./node_modules/.bin/jest --config jest.sheets.config.ts --runInBand --verbose --silent tests/services/gorse.service.test.ts tests/assessment/recommendations.assessment.test.ts --noStackTrace",
    "test:sheet:vector-search:clean": "./node_modules/.bin/jest --config jest.sheets.config.ts --runInBand --verbose --silent tests/services/qdrant.service.test.ts tests/assessment/vector-search.assessment.test.ts --noStackTrace",
    "test:sheet:ai-summaries:clean": "./node_modules/.bin/jest --config jest.sheets.config.ts --runInBand --verbose --silent tests/services/ollama.service.test.ts tests/services/gemini.service.test.ts tests/assessment/ai-summaries.assessment.test.ts --noStackTrace",
    "test:sheet:dashboard-analytics:clean": "./node_modules/.bin/jest --config jest.sheets.config.ts --runInBand --verbose --silent tests/api/dashboard.routes.test.ts tests/api/dashboard.extended-routes.test.ts --noStackTrace",
    "test:sheet:notifications-performance:clean": "./node_modules/.bin/jest --config jest.sheets.config.ts --runInBand --verbose --silent tests/services/notification.service.test.ts tests/workers/notification.worker.test.ts tests/assessment/notifications.assessment.test.ts --noStackTrace",
    "test:sheet:recommendations:proof": "node scripts/run-jest-proof.js --config jest.sheets.config.ts --runInBand --verbose --silent --noStackTrace tests/services/gorse.service.test.ts tests/assessment/recommendations.assessment.test.ts",
    "test:sheet:vector-search:proof": "node scripts/run-jest-proof.js --config jest.sheets.config.ts --runInBand --verbose --silent --noStackTrace tests/services/qdrant.service.test.ts tests/assessment/vector-search.assessment.test.ts",
    "test:sheet:ai-summaries:proof": "node scripts/run-jest-proof.js --config jest.sheets.config.ts --runInBand --verbose --silent --noStackTrace tests/services/ollama.service.test.ts tests/services/gemini.service.test.ts tests/assessment/ai-summaries.assessment.test.ts",
    "test:sheet:dashboard-analytics:proof": "node scripts/run-jest-proof.js --config jest.sheets.config.ts --runInBand --verbose --silent --noStackTrace tests/api/dashboard.routes.test.ts tests/api/dashboard.extended-routes.test.ts",
    "test:sheet:notifications-performance:proof": "node scripts/run-jest-proof.js --config jest.sheets.config.ts --runInBand --verbose --silent --noStackTrace tests/services/notification.service.test.ts tests/workers/notification.worker.test.ts tests/assessment/notifications.assessment.test.ts"
  },
  "dependencies": {
    "@chakra-ui/charts": "^3.29.0",
    "@chakra-ui/react": "^3.27.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google/genai": "^1.31.0",
    "@prisma/adapter-mariadb": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@qdrant/js-client-rest": "^1.16.2",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.62.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.24",
    "jose": "^6.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.5",
    "next": "15.5.9",
    "next-themes": "^0.4.6",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.10",
    "ollama": "^0.6.3",
    "pdf-parse": "^1.1.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0",
    "react-select": "^5.10.2",
    "recharts": "^3.4.1",
    "redis": "^5.9.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swiper": "^12.0.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/redis": "^4.0.11",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "eslint": "^9.37.0",
    "eslint-config-next": "15.5.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prisma": "^7.6.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  }
}
